datadir="/var/lib/proxysql"

admin_variables=
{
  admin_credentials="admin:admin"
  mysql_ifaces="0.0.0.0:6032"
}

mysql_variables=
{
  interfaces="0.0.0.0:6033"
  max_connections=2048
}

mysql_servers=
(
  {
    address="mysql"
    port=3306
    hostgroup=0
    max_connections=20
  }
)

mysql_users=
(
  {
    username="seu_user"
    password="sua_senha"
    default_hostgroup=0
  }
)